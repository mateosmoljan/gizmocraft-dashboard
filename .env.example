# Public Vercel UI
NEXTAUTH_URL=https://gizmocraft-dashboard.vercel.app
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Vercel -> gizmo-server bridge. Do not expose raw MySQL publicly.
MINECRAFT_BRIDGE_URL=https://your-gizmo-bridge.example.com
MINECRAFT_BRIDGE_TOKEN=

# Server-side DB/collector on gizmo-server laptop server.
# Use the real password only in .env.local or Vercel env vars, never in source control.
DATABASE_URL=mysql://gizmocraft_app:REDACTED@gizmo-server.tailfca8d2.ts.net:3306/gizmocraft_dashboard
MINECRAFT_WORLD_PATH=/home/cisco/minecraft-servers/gizmo-ivan/gizmo-ivan-dole

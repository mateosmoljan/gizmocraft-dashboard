# Public Vercel UI
NEXTAUTH_URL=https://minecraft-dashboard.example.com
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Vercel -> gizmo-server bridge. Do not expose MySQL directly.
MINECRAFT_BRIDGE_URL=https://your-gizmo-bridge.example.com
MINECRAFT_BRIDGE_TOKEN=

# Server-side bridge/collector only on gizmo-server
DATABASE_URL=mysql://minecraft_dashboard_user:REDACTED@gizmo-server:3306/minecraft_dashboard
MINECRAFT_WORLD_PATH=/home/cisco/minecraft-servers/gizmo-ivan/gizmo-ivan-dole
